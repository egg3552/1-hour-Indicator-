//@version=6
strategy("1H Intraday Setups — Backtest", overlay=true,
         default_qty_type  = strategy.percent_of_equity,
         default_qty_value = 10,
         max_bars_back     = 500,
         max_lines_count   = 500,
         max_labels_count  = 500)

// ═══════════════════════════════════════════════════════════════
// SECTION 1: INPUTS (identical to indicator)
// ═══════════════════════════════════════════════════════════════

// — Trend —
i_ema_fast    = input.int(9,   "Fast EMA",                 minval=1,            group="Trend")
i_ema_slow    = input.int(21,  "Slow EMA",                 minval=1,            group="Trend")
i_ema_trend   = input.int(50,  "Trend EMA",                minval=1,            group="Trend")
i_adx_len     = input.int(14,  "ADX Length",               minval=1,            group="Trend")
i_adx_min     = input.int(20,  "Min ADX (trend strength)", minval=10, maxval=50, group="Trend")

// — Momentum —
i_rsi_len     = input.int(14,  "RSI Length",    minval=2,            group="Momentum")
i_rsi_bull_hi = input.int(65,  "RSI Long Max",  minval=51, maxval=80, group="Momentum")
i_rsi_bear_lo = input.int(35,  "RSI Short Min", minval=20, maxval=49, group="Momentum")

// — Volume —
i_vol_mult    = input.float(1.5, "Volume Spike (×avg)", minval=1.0, step=0.1, group="Volume")
i_vol_ma_len  = input.int(20,    "Volume MA Length",    minval=5,             group="Volume")

// — Risk Management —
i_atr_len     = input.int(14,    "ATR Length",        minval=1,              group="Risk Management")
i_sl_mult     = input.float(1.5, "SL ATR Multiplier", minval=0.5, step=0.1,  group="Risk Management")
i_tp_rr       = input.float(1.0, "TP R:R",             minval=0.5, step=0.25, group="Risk Management")

// — Filters —
i_pivot_lb    = input.int(5,     "Pivot Lookback/Forward",   minval=2, group="Filters")
i_use_session = input.bool(false, "Enable Session Filter",              group="Filters")
i_session     = input.session("0930-1600", "Active Session (exchange time)", group="Filters")

// — Display —
i_show_emas    = input.bool(true, "Show EMAs (21 + 50)",      group="Display")
i_show_ranging = input.bool(true, "Show Consolidation Zones", group="Display")

// ═══════════════════════════════════════════════════════════════
// SECTION 2: CALCULATIONS (identical to indicator)
// ═══════════════════════════════════════════════════════════════

// ── 2a. ATR ──────────────────────────────────────────────────────
atr = ta.atr(i_atr_len)

// ── 2b. Trend: full EMA stack + ADX + HTF bias ──────────────────
ema_fast  = ta.ema(close, i_ema_fast)
ema_slow  = ta.ema(close, i_ema_slow)
ema_trend = ta.ema(close, i_ema_trend)

// ADX: confirms we are in a trend, not ranging
[_di_plus, _di_minus, adx_val] = ta.dmi(i_adx_len, i_adx_len)
adx_ok = adx_val >= i_adx_min

// Higher-timeframe EMA bias — 1H chart uses 4H as HTF
htf_tf = "240"

htf_ema   = request.security(syminfo.tickerid, htf_tf, ta.ema(close, 50), lookahead=barmerge.lookahead_off)
htf_close = request.security(syminfo.tickerid, htf_tf, close,              lookahead=barmerge.lookahead_off)

// Slope compared using a 4-bar offset (= one full 4H period on the 1H chart).
htf_slope_up = htf_ema > htf_ema[4]
htf_slope_dn = htf_ema < htf_ema[4]

// Full EMA stack required (9 > 21 > 50 for bull, reverse for bear)
trend_bull = ema_fast > ema_slow and ema_slow > ema_trend and close > ema_trend and htf_slope_up and htf_close > htf_ema
trend_bear = ema_fast < ema_slow and ema_slow < ema_trend and close < ema_trend and htf_slope_dn and htf_close < htf_ema

// ── 2c. Momentum: RSI sweet spot + MACD direction ────────────────
rsi = ta.rsi(close, i_rsi_len)
[_macd, _sig, hist] = ta.macd(close, 12, 26, 9)

// Long: RSI above midline but below overbought ceiling + MACD histogram positive and accelerating
mom_bull = rsi > 50 and rsi < i_rsi_bull_hi and hist > 0 and hist > hist[1]
// Short: RSI below midline but above oversold floor + MACD histogram negative and accelerating
mom_bear = rsi < 50 and rsi > i_rsi_bear_lo and hist < 0 and hist < hist[1]

// ── 2d. Volume: spike + directional candle alignment ─────────────
vol_ma    = ta.sma(volume, i_vol_ma_len)
vol_spike = volume > vol_ma * i_vol_mult

c_range  = high - low

vol_bull = vol_spike and close > open
vol_bear = vol_spike and close < open

// ── 2e. Entry trigger: EMA pullback OR structure breakout ─────────

// Confirmed pivot highs/lows
ph = ta.pivothigh(high, i_pivot_lb, i_pivot_lb)
pl = ta.pivotlow(low,   i_pivot_lb, i_pivot_lb)

var float last_ph_price = na
var float last_pl_price = na
var int   last_ph_bar   = na
var int   last_pl_bar   = na

if not na(ph)
    last_ph_price := ph
    last_ph_bar   := bar_index
if not na(pl)
    last_pl_price := pl
    last_pl_bar   := bar_index

// Candle body strength: body must be >65% of bar range
body_pct    = c_range > 0 ? math.abs(close - open) / c_range : 0.0
bull_candle = close > open and body_pct > 0.65
bear_candle = close < open and body_pct > 0.65

// EMA pullback: price touched EMA21 within last 4 bars, now bouncing above/below it
ema_pb_bull = ta.lowest(low,   4) <= ema_slow + atr * 0.5 and close > ema_slow and bull_candle
ema_pb_bear = ta.highest(high, 4) >= ema_slow - atr * 0.5 and close < ema_slow and bear_candle

// Structure: breakout/bounce with recency guard (20 bars from pivot confirmation)
str_bull_break  = bull_candle and not na(last_ph_price) and close > last_ph_price and close[1] <= last_ph_price
str_bull_bounce = bull_candle and not na(last_pl_price) and not na(last_pl_bar) and bar_index - last_pl_bar <= 20 and low <= last_pl_price + atr * 0.75 and close > last_pl_price
str_bull        = str_bull_break or str_bull_bounce

str_bear_break  = bear_candle and not na(last_pl_price) and close < last_pl_price and close[1] >= last_pl_price
str_bear_bounce = bear_candle and not na(last_ph_price) and not na(last_ph_bar) and bar_index - last_ph_bar <= 20 and high >= last_ph_price - atr * 0.75 and close < last_ph_price
str_bear        = str_bear_break or str_bear_bounce

trigger_bull = ema_pb_bull or str_bull
trigger_bear = ema_pb_bear or str_bear

// ── 2f. Session filter ────────────────────────────────────────────
in_session = i_use_session ? not na(time(timeframe.period, i_session, syminfo.timezone)) : true

// ── 2g. Previous day high / low / close (non-repainting) ─────────
pd_high  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
pd_low   = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)
pd_close = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)

near_pdh = math.abs(close - pd_high)  < atr * 0.5
near_pdl = math.abs(close - pd_low)   < atr * 0.5
near_pdc = math.abs(close - pd_close) < atr * 0.5
at_key_level = near_pdh or near_pdl or near_pdc

// ═══════════════════════════════════════════════════════════════
// SECTION 3: SIGNAL LOGIC (identical to indicator)
// ═══════════════════════════════════════════════════════════════

// ── 3a. Confluence scores ─────────────────────────────────────────
long_score  = (trend_bull ? 1 : 0) + (mom_bull ? 1 : 0) + (vol_bull ? 1 : 0) + (trigger_bull ? 1 : 0)
short_score = (trend_bear ? 1 : 0) + (mom_bear ? 1 : 0) + (vol_bear ? 1 : 0) + (trigger_bear ? 1 : 0)

min_score  = adx_ok ? 3 : 4
ema_sep_ok = math.abs(ema_slow - ema_trend) > atr * 0.2

raw_long  = long_score  >= min_score and in_session and ema_sep_ok
raw_short = short_score >= min_score and in_session and ema_sep_ok

// ── 3b. Daily signal gate (1 signal per day max) ─────────────────
var bool daily_used = false

if dayofmonth != dayofmonth[1] or month != month[1]
    daily_used := false

daily_ok = not daily_used

valid_long  = raw_long  and daily_ok
valid_short = raw_short and daily_ok

if valid_long or valid_short
    daily_used := true

// ── 3c. SL / TP ───────────────────────────────────────────────────
recent_low  = ta.lowest(low,  10)
recent_high = ta.highest(high, 10)

sl_long  = math.min(recent_low,  close - atr * i_sl_mult) - atr * 0.1
sl_short = math.max(recent_high, close + atr * i_sl_mult) + atr * 0.1

risk_long  = math.max(close - sl_long,  syminfo.mintick)
risk_short = math.max(sl_short - close, syminfo.mintick)

tp_long  = close + risk_long  * i_tp_rr
tp_short = close - risk_short * i_tp_rr

// ═══════════════════════════════════════════════════════════════
// SECTION 4: STRATEGY ENTRIES + EXITS
// ═══════════════════════════════════════════════════════════════

// ── 4a. Entries and exits registered together on the signal bar.
// TradingView executes entries at next bar open (process_orders_on_close=false default).
// Single full exit at TP (1:1 R:R by default) — multi-TP scaling is not modelled
// because "move SL to breakeven after TP1" cannot be implemented in the strategy tester,
// which would make TP2/TP3 carry the full original risk (unlike live trading).
// Commission and slippage: set in Strategy Tester → Properties.

if valid_long
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", from_entry="Long", stop=sl_long, limit=tp_long)

if valid_short
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", from_entry="Short", stop=sl_short, limit=tp_short)

// ═══════════════════════════════════════════════════════════════
// SECTION 5: VISUALS (minimal — for chart reference only)
// ═══════════════════════════════════════════════════════════════

// ── 5a. EMAs ──────────────────────────────────────────────────────
plot(i_show_emas ? ema_slow  : na, "EMA 21", color=color.new(color.blue,   15), linewidth=2)
plot(i_show_emas ? ema_trend : na, "EMA 50", color=color.new(color.orange, 10), linewidth=2)

// ── 5b. Consolidation zone ────────────────────────────────────────
bgcolor(i_show_ranging and not ema_sep_ok ? color.new(color.gray, 82) : na,
        title="Consolidation Zone")
